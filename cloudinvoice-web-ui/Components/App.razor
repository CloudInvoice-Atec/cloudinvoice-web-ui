    <script src="assets/libs/pdfmake/build/pdfmake.min.js"></script>
    <script src="assets/libs/pdfmake/build/vfs_fonts.js"></script>

    <script>
            // Função cirúrgica para carregar init.js apenas em páginas específicas
    window.carregarScriptLocal = function(scriptUrl) {
        // 1. Limpa o script se ele já existir de uma visita anterior a esta página
        var oldScript = document.querySelector('script[src="' + scriptUrl + '"]');
        if (oldScript) {
            oldScript.remove();
        }

        // 2. Injeta o script fresco para ele correr imediatamente
        var script = document.createElement('script');
        script.src = scriptUrl;
        document.body.appendChild(script);
    }; 
    </script>
    <script >
        window.recarregarScriptsDoTemplate = function() {
            // 1. Apaga o script antigo
            var oldScript = document.getElementById('template-app-js');
            if (oldScript) {
                oldScript.remove();
            }

            // 2. Cria o novo script
            var newScript = document.createElement('script');
            newScript.id = 'template-app-js';
            newScript.src = '/assets/js/app.min.js';

            // 3. Quando o script carregar, tentar forçar a reinicialização (se o template suportar)
            newScript.onload = function() {
                if (typeof window.InitApp !== 'undefined') {
                    window.InitApp(); // Alguns templates têm esta função global
                }
                // Força o SimpleBar a recalcular, se existir
                var scrollElements = document.querySelectorAll('[data-simplebar]');
                if (scrollElements.length > 0 && typeof SimpleBar !== 'undefined') {
                    scrollElements.forEach(function(el) {
                        new SimpleBar(el);
                    });
                }
            };

            document.body.appendChild(newScript);
        };

    window.iniciarMinhaDataTable = function(tabelaId) {
        var $table = $(tabelaId);

        // 1. REGRA DE OURO DO BLAZOR: Destruir a tabela anterior se ela já existir
        // Isto impede que o Blazor e o DataTables se atropelem ao mudar de página
        if ($.fn.DataTable.isDataTable($table)) {
            $table.DataTable().destroy();
        }

        // 2. Inicializar a DataTables com a tradução e os estilos do Ubold
        $table.DataTable({
            language: {
                // Aqui colocas o caminho exato para o teu ficheiro JSON de português!
                url: '/assets/libs/datatables.net/lang/pt.json'
            },
            pageLength: 10,
            drawCallback: function() {
                // Garante que a paginação fica com as bordas arredondadas (Estilo do template)
                $('.dataTables_paginate > .pagination').addClass('pagination-rounded');
            }
        });
    };
    </script>
</body>

</html>
