@layout Layout.AdminLayout
@inject IJSRuntime JS
@page "/backoffice/configuracoes/empresa"
@using cloudinvoice_web_ui.DTOs.Configuracoes



<div class="container-fluid">

    <!-- start page title -->
    <div class="row">
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="javascript: void(0);">Configurações</a></li>
                        <li class="breadcrumb-item active">Empresa</li>
                    </ol>
                </div>
                <h4 class="page-title">Empresa</h4>
            </div>
        </div>
    </div>
    <!-- end page title -->

    <EditForm Model="@_empresaDto" OnValidSubmit="SaveData">
        <DataAnnotationsValidator />

        <div class="row">
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="text-uppercase bg-light p-2 mt-0 mb-3">Dados Gerais</h5>

                        <div class="mb-3">
                            <label for="company-name" class="form-label">Nome <span class="text-danger">*</span></label>
                            <InputText id="company-name" class="form-control" placeholder="" @bind-Value="_empresaDto.Name" />
                            <ValidationMessage For="@(() => _empresaDto.Name)" class="text-danger mt-1" />
                        </div>
                        <div class="mb-3">
                            <label for="company-taxnumber" class="form-label">NIF <span class="text-danger">*</span></label>
                            <InputText id="company-taxnumber" class="form-control" placeholder="e.g : PT123456789" @bind-Value="_empresaDto.TaxNumber" />
                            <ValidationMessage For="@(() => _empresaDto.TaxNumber)" class="text-danger mt-1" />
                        </div>
                        <div class="mb-3">
                            <label for="company-address" class="form-label">Morada <span class="text-danger">*</span></label>
                            <InputText id="company-address" class="form-control" placeholder="e.g : Rua Exemplo, 123" @bind-Value="_empresaDto.Address" />
                            <ValidationMessage For="@(() => _empresaDto.Address)" class="text-danger mt-1" />
                        </div>
                        <div class="mb-3">
                            <label for="company-city" class="form-label">Localidade <span class="text-danger">*</span></label>
                            <InputText id="company-city" class="form-control" placeholder="e.g : Lisboa" @bind-Value="_empresaDto.City" />
                            <ValidationMessage For="@(() => _empresaDto.City)" class="text-danger mt-1" />
                        </div>
                        <div class="mb-3">
                            <label for="company-postalcode" class="form-label">Código Postal <span class="text-danger">*</span></label>
                            <InputText id="company-postalcode" class="form-control" placeholder="e.g : 1234-567" @bind-Value="_empresaDto.PostalCode" />
                            <ValidationMessage For="@(() => _empresaDto.PostalCode)" class="text-danger mt-1" />
                        </div>
                        <div class="mb-3">
                            <label for="company-country" class="form-label">País <span class="text-danger">*</span></label>
                            <InputSelect id="company-country" class="form-select select2" @bind-Value="_empresaDto.CountryId">
                                <option value="1">Portugal</option>
                                <option value="2">Espanha</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => _empresaDto.CountryId)" class="text-danger mt-1" />
                        </div>
                    </div>
                </div> <!-- end card -->
            </div> <!-- end col -->

            <div class="col-lg-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="text-uppercase mt-0 mb-3 bg-light p-2">Logótipo</h5>
                        <div class="mb-3">
                            <InputFile OnChange="ReceiveFile" class="form-control" accept=".png, .jpg, .jpeg" />

                            @if (!string.IsNullOrEmpty(_logoError))
                            {
                                <div class="text-danger mt-1">@_logoError</div>
                            }

                            @if (string.IsNullOrEmpty(_logoError) && _empresaDto.Logo != null)
                            {
                                <small class="text-success mt-1">Ficheiro selecionado: @_empresaDto.Logo.Name</small>
                            }
                        </div>
                    </div>
                </div>
                <div class="card">
                    <div class="card-body">
                        <h5 class="text-uppercase mt-0 mb-3 bg-light p-2">Informação de Contacto</h5>
                        <div class="mb-3">
                            <label for="company-email" class="form-label">Email <span class="text-danger">*</span></label>
                            <InputText id="company-email" class="form-control" placeholder="e.g : exemplo@dominio.com" @bind-Value="_empresaDto.Email" />
                            <ValidationMessage For="@(() => _empresaDto.Email)" class="text-danger mt-1" />
                        </div>
                        <div class="mb-3">
                            <label for="company-phone" class="form-label">Telefone <span class="text-danger">*</span></label>
                            <InputText id="company-phone" class="form-control" placeholder="e.g : +351 912 345 678" @bind-Value="_empresaDto.Phone" />
                            <ValidationMessage For="@(() => _empresaDto.Phone)" class="text-danger mt-1" />
                        </div>
                        <div class="mb-3">
                            <label for="company-website" class="form-label">Website</label>
                            <InputText id="company-website" class="form-control" placeholder="e.g : https://www.exemplo.com" @bind-Value="_empresaDto.Website" />
                            <ValidationMessage For="@(() => _empresaDto.Website)" class="text-danger mt-1" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="text-uppercase mt-0 mb-3 bg-light p-2">Informação Legal</h5>
                        <div class="mb-3">
                            <label for="company-registry-office" class="form-label">Conservatória</label>
                            <InputText id="company-registry-office" class="form-control" placeholder="e.g : Conservatória de Registo Comercial" @bind-Value="_empresaDto.RegistryOffice" />
                            <ValidationMessage For="@(() => _empresaDto.RegistryOffice)" class="text-danger mt-1" />
                        </div>
                        <div class="mb-3">
                            <label for="company-registration-number" class="form-label">Número de Registo Comercial</label>
                            <InputText id="company-registration-number" class="form-control" placeholder="e.g : 123456789" @bind-Value="_empresaDto.CommercialRegistrationNumber" />
                            <ValidationMessage For="@(() => _empresaDto.CommercialRegistrationNumber)" class="text-danger mt-1" />
                        </div>
                        <div class="mb-3">
                            <label for="company-share-capital" class="form-label">Capital Social <span class="text-danger">*</span></label>
                            <InputNumber id="company-share-capital" class="form-control" placeholder="e.g : 10000" @bind-Value="_empresaDto.ShareCapital" />
                            <ValidationMessage For="@(() => _empresaDto.ShareCapital)" class="text-danger mt-1" />
                        </div>
                    </div>
                </div>
            </div> <!-- end col -->

            <div class="col-lg-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="text-uppercase mt-0 mb-3 bg-light p-2">Informação Bancária</h5>
                        <div class="mb-3">
                            <label for="company-bank-name" class="form-label">Nome do Banco <span class="text-danger">*</span></label>
                            <InputText id="company-bank-name" class="form-control" placeholder="e.g : Banco Exemplo" @bind-Value="_empresaDto.BankName" />
                            <ValidationMessage For="@(() => _empresaDto.BankName)" class="text-danger mt-1" />
                        </div>
                        <div class="mb-3">
                            <label for="company-iban" class="form-label">IBAN <span class="text-danger">*</span></label>
                            <InputText id="company-iban" class="form-control" placeholder="e.g : PT50 1234 5678 9012 3456 7890 1" @bind-Value="_empresaDto.Iban" />
                            <ValidationMessage For="@(() => _empresaDto.Iban)" class="text-danger mt-1" />
                        </div>
                        <div class="mb-3">
                            <label for="company-swift" class="form-label">SWIFT <span class="text-danger">*</span></label>
                            <InputText id="company-swift" class="form-control" placeholder="e.g : ABCDPTPL" @bind-Value="_empresaDto.Swift" />
                            <ValidationMessage For="@(() => _empresaDto.Swift)" class="text-danger mt-1" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- end row -->

        <div class="row">
            <div class="col-12">
                <div class="text-center mb-3">
                    <button type="button" class="btn w-sm btn-light waves-effect">Cancelar</button>
                    <button type="submit" class="btn w-sm btn-success waves-effect waves-light">Guardar</button>
                    <button type="button" class="btn w-sm btn-danger waves-effect waves-light">Eliminar</button>
                </div>
            </div> <!-- end col -->
        </div>
        <!-- end row -->

    </EditForm>

</div> <!-- container -->

@code {
    private EmpresaDto _empresaDto = new EmpresaDto();
    private string _logoError;
    private long _maxFileSize = 10485760; // 10 MB em Bytes

    private void ReceiveFile(InputFileChangeEventArgs e)
    {
        _logoError = null;
        _empresaDto.Logo = null;

        var file = e.File;

        var extension = Path.GetExtension(file.Name).ToLowerInvariant();
        if (extension != ".png" && extension != ".jpg" && extension != ".jpeg")
        {
            _logoError = "Formato inválido. Por favor, escolha um ficheiro .png ou .jpg.";
            return;
        }

        if (file.Size > _maxFileSize)
        {
            _logoError = "O ficheiro é demasiado grande. O tamanho máximo permitido é 10MB.";
            return;
        }

        _empresaDto.Logo = file;
    }

    private async Task SaveData()
    {
        // await _empresaService.CreateAsync(_empresaDto);
        Console.WriteLine("Tudo válido! A gravar na base de dados...");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("carregarScriptLocal", "/assets/js/pages/configuracoes-empresa.init.js");
        }
    }
}