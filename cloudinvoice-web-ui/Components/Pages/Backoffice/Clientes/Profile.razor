@layout Layout.AdminLayout
@inject IJSRuntime JS

@page "/backoffice/clientes/{Id:guid}"
@page "/backoffice/clientes/perfil-teste"

<div class="container-fluid">

    <!-- Cabeçalho da Página -->
    <div class="row">
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <a href="/backoffice/clientes" class="btn btn-secondary waves-effect waves-light">
                        <i class="mdi mdi-arrow-left me-1"></i> Voltar à Lista
                    </a>
                </div>
                <h4 class="page-title">Perfil do Cliente</h4>
            </div>
        </div>
    </div>

    @if (cliente == null)
    {
        <!-- Estado de Carregamento -->
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">A carregar dados do cliente...</p>
        </div>
    }
    else
    {
        <div class="row">
            <!-- COLUNA ESQUERDA: Resumo Rápido -->
            <div class="col-xl-4 col-lg-5">
                <div class="card text-center">
                    <div class="card-body">
                        <!-- Avatar / Iniciais do Cliente -->
                        <div class="avatar-xl mx-auto mb-3">
                            <span class="avatar-title bg-soft-primary text-primary rounded-circle font-24">
                                @cliente.Nome.Substring(0, 1).ToUpper()
                            </span>
                        </div>

                        <h4 class="mb-0">@cliente.Nome</h4>
                        <p class="text-muted">NIF: @cliente.Nif</p>

                        <div class="mb-3">
                            @if (cliente.IsAtivo)
                            {
                                <span class="badge bg-success font-13">Cliente Ativo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger font-13">Cliente Inativo</span>
                            }
                        </div>

                        <div class="text-start mt-4 pt-2 border-top">
                            <h4 class="font-13 text-uppercase mb-3">Resumo Financeiro</h4>
                            <p class="text-muted mb-2 font-13"><strong>Em Dívida:</strong> <span class="ms-2 text-danger">@cliente.DividaAtual.ToString("C")</span></p>
                            <p class="text-muted mb-2 font-13"><strong>Limite Crédito:</strong> <span class="ms-2">@cliente.LimiteCredito.ToString("C")</span></p>
                            <p class="text-muted mb-2 font-13"><strong>Condições Pag.:</strong> <span class="ms-2">@cliente.DiasPagamento Dias</span></p>
                        </div>

                        <div class="text-start mt-4 pt-2 border-top">
                            <h4 class="font-13 text-uppercase mb-3">Contactos Principais</h4>
                            <p class="text-muted mb-2 font-13"><strong>Email:</strong> <span class="ms-2">@cliente.EmailPrincipal</span></p>
                            <p class="text-muted mb-2 font-13"><strong>Telefone:</strong> <span class="ms-2">@cliente.TelefonePrincipal</span></p>
                            <p class="text-muted mb-1 font-13"><strong>Morada:</strong> <span class="ms-2">@cliente.Morada</span></p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- COLUNA DIREITA: Separadores com a Informação Densa -->
            <div class="col-xl-8 col-lg-7">
                <div class="card">
                    <div class="card-body">
                        <!-- Menu das Tabs -->
                        <ul class="nav nav-pills nav-fill navtab-bg">
                            <li class="nav-item">
                                <a href="#detalhes" data-bs-toggle="tab" aria-expanded="true" class="nav-link active">
                                    Detalhes e Edição
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="#pessoas" data-bs-toggle="tab" aria-expanded="false" class="nav-link">
                                    Pessoas
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="#faturas" data-bs-toggle="tab" aria-expanded="false" class="nav-link">
                                    Histórico de Faturas
                                </a>
                            </li>
                        </ul>

                        <!-- Conteúdo das Tabs -->
                        <div class="tab-content">

                            <!-- TAB 1: Detalhes -->
                            <div class="tab-pane show active" id="detalhes">
                                <EditForm Model="@cliente" OnValidSubmit="GravarAlteracoes">
                                    <DataAnnotationsValidator />

                                    <h5 class="mb-3 text-uppercase bg-light p-2"><i class="mdi mdi-office-building me-1"></i> Dados da Empresa</h5>
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Nome Completo</label>
                                            <InputText @bind-Value="cliente.Nome" class="form-control" />
                                            <ValidationMessage For="@(() => cliente.Nome)" class="text-danger mt-1" />
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Nome Comercial (Marca)</label>
                                            <InputText @bind-Value="cliente.NomeComercial" class="form-control" />
                                        </div>
                                    </div>

                                    <h5 class="mb-3 text-uppercase bg-light p-2"><i class="mdi mdi-currency-eur me-1"></i> Dados Fiscais e Faturação</h5>
                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label">Desconto Padrão (%)</label>
                                            <InputNumber @bind-Value="cliente.DescontoPadrao" class="form-control" />
                                        </div>
                                        <div class="col-md-8 mb-3">
                                            <label class="form-label">Motivo de Isenção de IVA (Se aplicável)</label>
                                            <InputSelect @bind-Value="cliente.MotivoIsencaoIva" class="form-select">
                                                <option value="">Não Isento</option>
                                                <option value="M01">M01 - Artigo 16.º n.º 6 do CIVA</option>
                                                <option value="M02">M02 - Artigo 6.º do Decreto-Lei n.º 198/90</option>
                                            </InputSelect>
                                        </div>
                                    </div>

                                    <div class="text-end">
                                        <button type="submit" class="btn btn-success mt-2"><i class="mdi mdi-content-save"></i> Guardar Alterações</button>
                                    </div>
                                </EditForm>
                            </div>

                            <!-- TAB 2: Pessoas -->
                            <div class="tab-pane" id="pessoas">
                                <div class="text-end mb-3">
                                    <button class="btn btn-sm btn-primary">Adicionar Pessoa</button>
                                </div>
                                <div class="table-responsive">
                                    <table class="table table-borderless table-centered table-nowrap mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Nome</th>
                                                <th>Cargo</th>
                                                <th>Email</th>
                                                <th>Ação</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td>João Silva</td>
                                                <td>Comercial</td>
                                                <td>joao@cliente.pt</td>
                                                <td>
                                                    <a href="javascript:void(0);" class="action-icon"> <i class="mdi mdi-square-edit-outline"></i></a>
                                                    <a href="javascript:void(0);" class="action-icon text-danger"> <i class="mdi mdi-delete"></i></a>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <!-- TAB 3: Faturas -->
                            <div class="tab-pane" id="faturas">
                                <p class="text-muted">A listagem de faturas deste cliente aparecerá aqui.</p>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    // 1. Receber o GUID do URL
    [Parameter]
    public Guid? Id { get; set; }

    // 2. A variável que vai segurar os dados (pode ser o teu DTO real)
    private ClientePerfilDto cliente;

    // 3. O método que corre quando a página abre
    protected override async Task OnInitializedAsync()
    {
        // Aqui farias: cliente = await MeuServicoApi.ObterClientePorIdAsync(Id);

        // Vamos simular um pequeno atraso de rede (meio segundo) para veres o Loading spinner a funcionar
        await Task.Delay(500);

        // Mock dos dados para a página não estoirar enquanto não ligas a API
        cliente = new ClientePerfilDto
        {
            Id = this.Id ?? Guid.NewGuid(),
            Nome = "Tech Solutions, Lda",
            NomeComercial = "TechSol",
            Nif = "500123456",
            IsAtivo = true,
            DividaAtual = 1250.00m,
            LimiteCredito = 5000.00m,
            DiasPagamento = 30,
            EmailPrincipal = "geral@techsolutions.pt",
            TelefonePrincipal = "+351 253 111 222",
            Morada = "Rua da Inovação, 45, 4800-000 Guimarães",
            DescontoPadrao = 0
        };
    }

    private async Task GravarAlteracoes()
    {
        // Aqui chamas a API para gravar os dados do tab "Detalhes"
        // await MeuServicoApi.AtualizarClienteAsync(Id, cliente);
        Console.WriteLine($"Dados do cliente {cliente.Nome} guardados com sucesso!");
    }

    // --- DTO Temporário apenas para o ficheiro compilar (depois removes e usas o teu) ---
    public class ClientePerfilDto
    {
        public Guid? Id { get; set; }
        public string Nome { get; set; }
        public string NomeComercial { get; set; }
        public string Nif { get; set; }
        public bool IsAtivo { get; set; }
        public decimal DividaAtual { get; set; }
        public decimal LimiteCredito { get; set; }
        public int DiasPagamento { get; set; }
        public string EmailPrincipal { get; set; }
        public string TelefonePrincipal { get; set; }
        public string Morada { get; set; }
        public decimal DescontoPadrao { get; set; }
        public string MotivoIsencaoIva { get; set; }
    }
}