@layout Layout.PublicLayout
@inject IJSRuntime JS
@page "/connection-api"

<h4 class="mt-0">Teste de Ligação</h4>
<p class="text-muted mb-4">Aqui pode verificar o estado de cada API integrada com a plataforma.</p>

<div class="d-flex mb-3 align-items-center">
    <div class="col-md-8">
        <h5 class="font-size-14 mb-1">Billing API</h5>
        <p class="text-muted font-size-13">Verifica a ligação com a Billing API.</p>
    </div>
    <div class="col-md-2 offset-md-2 text-center">
        @if (!isBillingAPISuccess && !isBillingAPIFailure)
        {
            //coloar um botao com animação de loading enquanto o teste está a decorrer
            @if(!isBillingAPILoading && !isBillingAPISuccess && !isBillingAPIFailure)
            {
                <button class="btn btn-primary" id="billing-api-button" @onclick="TestBillingAPI">Testar</button>
            }
            else if(isBillingAPILoading && !isBillingAPISuccess && !isBillingAPIFailure)
            {
                <div class="spinner-border text-primary m-2" role="status"></div>
            }
        }
        @if (isBillingAPISuccess)
        {
            <div class="test-success">
                <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 130.2 130.2">
                    <circle class="path circle" fill="none" stroke="#4bd396" stroke-width="6" stroke-miterlimit="10" cx="65.1" cy="65.1" r="62.1"/>
                    <polyline class="path check" fill="none" stroke="#4bd396" stroke-width="6" stroke-linecap="round" stroke-miterlimit="10" points="100.2,40.2 51.5,88.8 29.8,67.5 "/>
                </svg>
            </div>
        }
        @if (isBillingAPIFailure)
        {
            <div class="test-failure">
                <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 130.2 130.2">
                    <circle class="path circle" fill="none" stroke="#f46a6a" stroke-width="6" stroke-miterlimit="10" cx="65.1" cy="65.1" r="62.1"/>
                    <line class="path line" fill="none" stroke="#f46a6a" stroke-width="6" stroke-linecap="round" stroke-miterlimit="10" x1="34.4" y1="37.9" x2="95.8" y2="92.3"/>
                    <line class="path line" fill="none" stroke="#f46a6a" stroke-width="6" stroke-linecap="round" stroke-miterlimit="10" x1="95.8" y1="38.1" x2="34.4" y2="92.5"/>
                </svg>
            </div>
        }
    </div>
</div>

<div class="d-flex mb-3 align-items-center">
    <div class="col-md-8">
        <h5 class="font-size-14 mb-1">Catalog API</h5>
        <p class="text-muted font-size-13">Verifica a ligação com a Catalog API.</p>
    </div>
    <div class="col-md-2 offset-md-2 text-center">
        @if (!isCatalogAPISuccess && !isCatalogAPIFailure)
        {
            //coloar um botao com animação de loading enquanto o teste está a decorrer
            @if(!isCatalogAPILoading && !isCatalogAPISuccess && !isCatalogAPIFailure)
            {
                <button class="btn btn-primary" id="catalog-api-button" @onclick="TestCatalogAPI">Testar</button>
            }
            else if(isCatalogAPILoading && !isCatalogAPISuccess && !isCatalogAPIFailure)
            {
                <div class="spinner-border text-primary m-2" role="status"></div>
            }

        }
        @if (isCatalogAPISuccess)
        {
            <div class="test-success">
                <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 130.2 130.2">
                    <circle class="path circle" fill="none" stroke="#4bd396" stroke-width="6" stroke-miterlimit="10" cx="65.1" cy="65.1" r="62.1"/>
                    <polyline class="path check" fill="none" stroke="#4bd396" stroke-width="6" stroke-linecap="round" stroke-miterlimit="10" points="100.2,40.2 51.5,88.8 29.8,67.5 "/>
                </svg>
            </div>
        }
        @if (isCatalogAPIFailure)
        {
            <div class="test-failure">
                <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 130.2 130.2">
                    <circle class="path circle" fill="none" stroke="#f46a6a" stroke-width="6" stroke-miterlimit="10" cx="65.1" cy="65.1" r="62.1"/>
                    <line class="path line" fill="none" stroke="#f46a6a" stroke-width="6" stroke-linecap="round" stroke-miterlimit="10" x1="34.4" y1="37.9" x2="95.8" y2="92.3"/>
                    <line class="path line" fill="none" stroke="#f46a6a" stroke-width="6" stroke-linecap="round" stroke-miterlimit="10" x1="95.8" y1="38.1" x2="34.4" y2="92.5"/>
                </svg>
            </div>
        }
    </div>
</div>

<div class="d-flex mb-3 align-items-center">
    <div class="col-md-8">
        <h5 class="font-size-14 mb-1">Identity API</h5>
        <p class="text-muted font-size-13">Verifica a ligação com a Identity API.</p>
    </div>
    <div class="col-md-2 offset-md-2 text-center">
        @if (!isIdentityAPISuccess && !isIdentityAPIFailure)
        {
            //coloar um botao com animação de loading enquanto o teste está a decorrer
            @if (!isIdentityAPILoading && !isIdentityAPISuccess && !isIdentityAPIFailure)
            {
                <button class="btn btn-primary" id="identity-api-button" @onclick="TestIdentityAPI">Testar</button>
            }
            else if (isIdentityAPILoading && !isIdentityAPISuccess && !isIdentityAPIFailure)
            {
                <div class="spinner-border text-primary m-2" role="status"></div>
            }
        }
        @if (isIdentityAPISuccess)
        {
            <div class="test-success">
                <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 130.2 130.2">
                    <circle class="path circle" fill="none" stroke="#4bd396" stroke-width="6" stroke-miterlimit="10" cx="65.1" cy="65.1" r="62.1"/>
                    <polyline class="path check" fill="none" stroke="#4bd396" stroke-width="6" stroke-linecap="round" stroke-miterlimit="10" points="100.2,40.2 51.5,88.8 29.8,67.5 "/>
                </svg>
            </div>
        }
        @if (isIdentityAPIFailure)
        {
            <div class="test-failure">
                <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 130.2 130.2">
                    <circle class="path circle" fill="none" stroke="#f46a6a" stroke-width="6" stroke-miterlimit="10" cx="65.1" cy="65.1" r="62.1"/>
                    <line class="path line" fill="none" stroke="#f46a6a" stroke-width="6" stroke-linecap="round" stroke-miterlimit="10" x1="34.4" y1="37.9" x2="95.8" y2="92.3"/>
                    <line class="path line" fill="none" stroke="#f46a6a" stroke-width="6" stroke-linecap="round" stroke-miterlimit="10" x1="95.8" y1="38.1" x2="34.4" y2="92.5"/>
                </svg>
            </div>
        }
    </div>
</div>

<footer class="footer footer-alt">
    <p class="text-muted">@DateTime.Now.Year &copy; CloudInvoice</p>
</footer>

@code {
	private bool isBillingAPISuccess = false;
	private bool isBillingAPIFailure = false;
    private bool isBillingAPILoading = false;

	private bool isCatalogAPISuccess = false;
	private bool isCatalogAPIFailure = false;
    private bool isCatalogAPILoading = false;

	private bool isIdentityAPISuccess = false;
	private bool isIdentityAPIFailure = false;
    private bool isIdentityAPILoading = false;

	private async Task TestBillingAPI()
	{
        isBillingAPILoading = true;
		try
		{
			using var httpClient = new HttpClient();
			var response = await httpClient.GetAsync("https://localhost:5005/api/system/health");
			if (response.IsSuccessStatusCode)
			{
				isBillingAPISuccess = true;
                isBillingAPIFailure = false;
                isBillingAPILoading = false;

            }
            else
            {
                isBillingAPISuccess = false;
                isBillingAPIFailure = true;
                isBillingAPILoading = false;
            }
        }
        catch
        {
            isBillingAPISuccess = false;
            isBillingAPIFailure = true;
            isBillingAPILoading = false;
        }
    }

    private async Task TestCatalogAPI()
    {
        isCatalogAPILoading = true;
        try
        {
            using var httpClient = new HttpClient();
            var response = await httpClient.GetAsync("https://localhost:5003/api/system/health");
            if (response.IsSuccessStatusCode)
            {
                isCatalogAPISuccess = true;
                isCatalogAPIFailure = false;
                isCatalogAPILoading = false;
            }
            else
            {
                isCatalogAPISuccess = false;
                isCatalogAPIFailure = true;
                isCatalogAPILoading = false;
            }
        }
        catch
        {
            isCatalogAPISuccess = false;
            isCatalogAPIFailure = true;
            isCatalogAPILoading = false;
        }
    }

    private async Task TestIdentityAPI()
    {
        isIdentityAPILoading = true;
        try
        {
            using var httpClient = new HttpClient();
            var response = await httpClient.GetAsync("https://localhost:5001/api/system/health");
            if (response.IsSuccessStatusCode)
            {
                isIdentityAPISuccess = true;
                isIdentityAPIFailure = false;
                isIdentityAPILoading = false;
            }
            else
            {
                isIdentityAPISuccess = false;
                isIdentityAPIFailure = true;
                isIdentityAPILoading = false;
            }
        }
        catch
        {
            isIdentityAPISuccess = false;
            isIdentityAPIFailure = true;
            isIdentityAPILoading = false;
        }
    }
}
